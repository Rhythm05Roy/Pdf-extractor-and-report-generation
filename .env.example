# LLM Configuration — Priority: OpenAI → Gemini → Ollama → Stub
# Set at least ONE API key to enable AI draft generation.

# OPTION 1 — OpenAI (recommended, most reliable)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OPTION 2 — Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OPTION 3 — Ollama local LLM (set USE_OLLAMA_FALLBACK=true to enable)
USE_OLLAMA_FALLBACK=false
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# OCR
TESSERACT_CMD=/usr/bin/tesseract

# Storage paths (relative to the legalMind/ directory)
CHROMA_DB_PATH=./data/chroma_db
EDITS_DB_PATH=./data/edits.db
PATTERNS_FILE=./data/edit_patterns.json

# Pipeline settings
LOG_LEVEL=INFO
RETRIEVAL_TOP_K=8
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
