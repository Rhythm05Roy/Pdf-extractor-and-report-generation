# LegalMind — Environment Configuration Template
# Copy this file to .env and fill in your keys.
# LLM Priority: OpenAI → Mistral → Gemini → Ollama → Stub
# OCR Priority: Mistral OCR → Tesseract

# ── OPTION 1: OpenAI (LLM drafts — recommended) ───────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── OPTION 2: Mistral (OCR + LLM drafts) ─────────────────────────────────────
# Get your key at: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_OCR_MODEL=mistral-ocr-latest
USE_MISTRAL_OCR=true

# ── OPTION 3: Google Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── OPTION 4: Ollama (local, no API key required) ────────────────────────────
USE_OLLAMA_FALLBACK=false
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── OCR ───────────────────────────────────────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract

# ── Storage paths (relative to legalMind/ directory) ─────────────────────────
CHROMA_DB_PATH=./data/chroma_db
EDITS_DB_PATH=./data/edits.db
PATTERNS_FILE=./data/edit_patterns.json

# ── Pipeline settings ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
RETRIEVAL_TOP_K=8
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MAX_EVIDENCE_CHUNKS=6
MAX_PATTERNS_IN_PROMPT=5
